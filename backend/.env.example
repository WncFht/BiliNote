
# 通用
ENV=production
API_BASE_URL=http://127.0.0.1:8000
SCREENSHOT_BASE_URL=http://127.0.0.1:8000/static/screenshots
STATIC=/static # 外部访问路径（URL 前缀）
OUT_DIR=./static/screenshots    # 本地输出目录
IMAGE_BASE_URL=/static/screenshots  # 图片访问 URL
DATA_DIR=data
DATABASE_URL=sqlite:///bili_note.db
HF_ENDPOINT=https://hf-mirror.com

# B 站字幕增强（可选但推荐）
BILIBILI_COOKIES_FILE=cookies.txt

# transcriber 相关配置
TRANSCRIBER_TYPE=fast-whisper # fast-whisper/bcut/kuaishou/mlx-whisper(仅Apple平台)/groq
WHISPER_MODEL_SIZE=base
GROQ_TRANSCRIBER_MODEL=whisper-large-v3-turbo

# 模型供应商 API Key
# 推荐在应用启动后，通过前端 Settings -> 模型供应商 填写。
# 下列变量主要用于兼容旧脚本或手动指定默认值，留空不影响应用启动。
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4

DEEP_SEEK_API_KEY=
DEEP_SEEK_API_BASE_URL=https://api.deepseek.com
DEEP_SEEK_MODEL=deepseek-chat

QWEN_API_KEY=
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
