# 通用端口配置
BACKEND_PORT=8483 # 后端端口
FRONTEND_PORT=3015
BACKEND_HOST=0.0.0.0 # 默认为 0.0.0.0，表示监听所有 IP 地址 不建议动
APP_PORT= 3015 # docker 部署时用
# 前端访问后端用 (开发环境使用)
VITE_API_BASE_URL=http://127.0.0.1:8483
VITE_SCREENSHOT_BASE_URL=http://127.0.0.1:8483/static/screenshots
VITE_FRONTEND_PORT=3015
# 生产环境配置
ENV=production
STATIC=/static
OUT_DIR=./static/screenshots
NOTE_OUTPUT_DIR=note_results
IMAGE_BASE_URL=/static/screenshots
DATA_DIR=data
DATABASE_URL=sqlite:///bili_note.db
# 国内网络建议保留 HF 镜像
HF_ENDPOINT=https://hf-mirror.com
# FFMPEG 配置
FFMPEG_BIN_PATH=

# B 站字幕增强（可选但推荐）
BILIBILI_COOKIES_FILE=cookies.txt

# transcriber 相关配置
TRANSCRIBER_TYPE=fast-whisper # fast-whisper/bcut/kuaishou/mlx-whisper(仅Apple平台)/groq
WHISPER_MODEL_SIZE=base

GROQ_TRANSCRIBER_MODEL=whisper-large-v3-turbo # groq提供的faster-whisper 默认为 whisper-large-v3-turbo

# 模型供应商 API Key
# 推荐在应用启动后，通过前端 Settings -> 模型供应商 填写。
# 下列变量主要用于兼容旧脚本或手动指定默认值，留空不影响应用启动。

# OpenAI（例如 gpt-5.4）
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4

# DeepSeek
DEEP_SEEK_API_KEY=
DEEP_SEEK_API_BASE_URL=https://api.deepseek.com
DEEP_SEEK_MODEL=deepseek-chat

# Qwen
QWEN_API_KEY=
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
